# ============================================================
# Strike Calculator — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# In production, Vercel auto-injects these from the dashboard
# (Settings → Environment Variables) and from Marketplace
# integrations (Neon, Upstash, Sentry, Blob).
#
# The canonical Zod schema for these vars lives in
# api/_lib/env.ts. Add new vars there too.

# ── Authentication ──────────────────────────────────────────
# Single-owner secret. Set to a long random string.
# The app uses a plaintext httpOnly cookie to gate writes.
OWNER_SECRET=

# Comma-separated guest read keys (optional). Guests get
# read-only access to data endpoints (dark pool, GEX, TRACE
# Live, etc.) — never to the Anthropic-backed analyze endpoint.
GUEST_ACCESS_KEYS=

# ── Schwab Market Data API ──────────────────────────────────
# Required for live quotes, intraday data, and options chain.
# Register at https://developer.schwab.com
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=

# ── Database (Neon Postgres) ────────────────────────────────
# Auto-created when you add Neon from the Vercel Marketplace.
# Pooled URL is used by @neondatabase/serverless in Vercel
# Functions. Unpooled URL is used by the Railway sidecar
# (psycopg2) and backfill scripts that hold long connections.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ── Cache / Token Store (Upstash Redis) ─────────────────────
# Auto-created when you add Upstash from the Vercel Marketplace.
# Either pair works — api/_lib/env.ts accepts KV_* or UPSTASH_*.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AI Chart Analysis (Anthropic) ──────────────────────────
# Required for the Chart Analysis feature (Claude Opus).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── AI Embeddings (OpenAI) ────────────────────────────────
# Required for lessons-learned dedup (text-embedding-3-small).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Futures Data (Databento) ──────────────────────────────
# Required for the futures sidecar (Railway) and daily
# gap-fill cron (Vercel). Streams OHLCV-1m for ES, NQ, ZN,
# RTY, CL, GC (CME), VX (CBOE — deferred), DX (ICE).
# Get a key at https://databento.com
DATABENTO_API_KEY=

# ── Market Data (Unusual Whales) ──────────────────────────
# Required for darkpool levels, options flow, Greek exposure,
# and the uw-stream Railway service (Advanced tier for WS).
UW_API_KEY=

# ── Cron Jobs ────────────────────────────────────────────
# Auto-provided by Vercel in production for cron auth.
# Set a random string for local testing.
CRON_SECRET=

# ── Internal Webhooks ─────────────────────────────────────
# Distinct from CRON_SECRET. Gates /api/periscope-auto-playbook
# (called by the periscope-scraper service on each new read).
PERISCOPE_WEBHOOK_SECRET=

# Gates /api/internal-notify (used by Railway services to push
# alerts back into the app — flow, lottery, etc.).
INTERNAL_NOTIFY_SECRET=

# ── Auto-Playbook Loop ────────────────────────────────────
# Kill switch for the Periscope auto-playbook loop.
# 'true' (default) | 'false' — set to 'false' to pause writes.
AUTO_PLAYBOOK_ENABLED=

# Public URL of the periscope-scraper Railway service (the
# UW Periscope OCR worker). Used to display reads in the UI.
PERISCOPE_URL=

# ── Vercel Blob ────────────────────────────────────────────
# Required for ML plot uploads, archive seeding, and DB backups.
# Auto-provided when Blob is added from the Vercel Marketplace.
BLOB_READ_WRITE_TOKEN=

# ── Sidecar URL ───────────────────────────────────────────
# Public URL of the Railway Databento sidecar service.
# Used by api/ to proxy futures + ES options requests.
SIDECAR_URL=

# ── Takeit ML Scoring Sidecar ─────────────────────────────
# Separate Python service that scores Lottery Finder candidates
# with the XGBoost model retrained nightly by the
# .github/workflows/takeit-retrain.yml workflow.
SIDECAR_TAKEIT_URL=
SIDECAR_TAKEIT_SECRET=

# ── Day-Analog Backend ────────────────────────────────────
# Which similarity engine to use for the "today vs. historical
# analog" feature. 'pgvector' (default) | 'in_memory'.
DAY_ANALOG_BACKEND=

# ── Web Push (PWA notifications) ──────────────────────────
# Optional. Required only if you want browser push alerts.
# Generate with: npx web-push generate-vapid-keys
# VAPID_SUBJECT is a mailto: URL or HTTPS origin you control.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# ── App URL ───────────────────────────────────────────────
# Public origin of this app. Used for OAuth callbacks,
# Sentry release tagging, and absolute URL construction.
# Local dev: http://localhost:3000
APP_URL=

# ── Error Tracking (Sentry) ────────────────────────────────
# Auto-created when you add Sentry from the Vercel Marketplace.
# SENTRY_AUTH_TOKEN is needed for source map uploads at build.
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── Logging ────────────────────────────────────────────────
# pino log level: trace | debug | info | warn | error | fatal
# Default: info
LOG_LEVEL=

# Optional Axiom dataset + key for log shipping.
AXIOM_DATASET=
AXIOM_API_KEY=

# ── SMS Alerts (Twilio) ──────────────────────────────────
# Optional. Used by the alert engine for futures momentum,
# VX backwardation, flight-to-safety, etc.
# All four must be set for SMS to send (see api/_lib/env.ts
# requireEnvGroup('twilio')).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_FROM=
# ALERT_PHONE_TO=

# ── Optional: Economic Data ────────────────────────────────
# FRED for VIX historical enrichment, Finnhub for company data.
FRED_API_KEY=
FINNHUB_API_KEY=

# ── Vercel Runtime (auto-injected — do NOT set locally) ────
# Documented here for reference. The platform sets these in
# production / preview / development environments.
# VERCEL=1
# VERCEL_ENV=production | preview | development
# NODE_ENV=production | development | test

# ── Railway-only services (NOT used by Vercel functions) ───
# These belong in the Railway dashboard for the sidecar /
# ml-sweep / uw-stream services, not in this file. Listed
# here as a reminder for whoever provisions Railway:
#
#   sidecar:   DATABENTO_API_KEY, DATABASE_URL_UNPOOLED,
#              SENTRY_DSN, THETA_EMAIL, THETA_PASSWORD,
#              ARCHIVE_MANIFEST_URL, ARCHIVE_SEED_TOKEN,
#              ARCHIVE_ROOT, BLOB_READ_WRITE_TOKEN,
#              RAILWAY_RUN_UID
#   ml-sweep:  ARCHIVE_MANIFEST_URL, ARCHIVE_ROOT,
#              BLOB_READ_WRITE_TOKEN, AUTH_TOKEN
#   uw-stream: UW_API_KEY, DATABASE_URL_UNPOOLED, SENTRY_DSN

# Gexbot API Key
GEXBOT_API_KEY=