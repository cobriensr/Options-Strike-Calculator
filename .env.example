# ============================================================
# Strike Calculator — Required Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Vercel auto-injects these from the dashboard (Settings → Environment Variables).

# ── Authentication ──────────────────────────────────────────
# Single-owner secret. Set this to a random string.
# The app uses a plaintext cookie to gate data writes.
OWNER_SECRET=

# ── Schwab Market Data API ──────────────────────────────────
# Required for live quotes, intraday data, and options chain.
# Register at https://developer.schwab.com
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=

# ── Database (Neon Postgres) ────────────────────────────────
# Auto-created when you add Neon from the Vercel Marketplace.
# Vercel provides multiple POSTGRES_* vars; DATABASE_URL is used
# by the sidecar and backfill scripts directly.
DATABASE_URL=

# ── Rate Limiting (Upstash Redis) ───────────────────────────
# Auto-created when you add Upstash from the Vercel Marketplace.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AI Chart Analysis (Anthropic) ──────────────────────────
# Required for the Chart Analysis feature (Claude Opus).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── AI Embeddings (OpenAI) ────────────────────────────────
# Required for the lessons learned dedup system (text-embedding-3-small).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Futures Data (Databento) ──────────────────────────────
# Required for the futures sidecar (Railway) and daily gap-fill cron (Vercel).
# Streams OHLCV-1m for ES, NQ, ZN, RTY, CL, GC (CME), VX (CBOE), DX (ICE).
# Get a key at https://databento.com
DATABENTO_API_KEY=

# ── Market Data (Unusual Whales) ──────────────────────────
# Required for darkpool levels, options flow, and Greek exposure.
UW_API_KEY=

# ── Cron Jobs ────────────────────────────────────────────
# Auto-provided by Vercel in production for cron auth.
# Set a random string for local testing.
CRON_SECRET=

# ── Error Tracking (Sentry) ────────────────────────────────
# Auto-created when you add Sentry from the Vercel Marketplace.
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── SMS Alerts (Twilio) ──────────────────────────────────
# Optional. Used by the sidecar alert engine to send SMS
# for futures momentum, VX backwardation, flight-to-safety, etc.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# ALERT_PHONE_NUMBER=

# ── Optional: Economic Data ────────────────────────────────
# Used for VIX historical data enrichment.
FRED_API_KEY=
FINNHUB_API_KEY=

# AXIOM

NEXT_PUBLIC_AXIOM_INGEST_ENDPOINT=
AXIOM_API_KEY=