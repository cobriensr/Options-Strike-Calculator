{
  "name": "0dte-strike-calculator",
  "private": true,
  "version": "1.0.0",
  "license": "GPL-3.0-only",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:full": "NODE_OPTIONS='--disable-warning=DEP0169' LOG_LEVEL=debug vercel dev | npx pino-pretty",
    "build": "tsc -b && vite build",
    "build:analyze": "ANALYZE=true tsc -b && ANALYZE=true vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "lint": "tsc --noEmit && eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "review": "tsc --noEmit && eslint . && prettier --write . && vitest run --coverage",
    "review:ml": "cd ml && make format && make test-cov",
    "review:sidecar": "cd sidecar && make format && make test-cov",
    "review:python": "npm run review:ml && npm run review:sidecar",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@neondatabase/serverless": "^1.0.2",
    "@sentry/node": "^10.44.0",
    "@sentry/react": "^10.44.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@upstash/redis": "^1.36.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "@vercel/speed-insights": "^2.0.0",
    "@vercel/toolbar": "^0.2.2",
    "botid": "^1.5.11",
    "openai": "^6.32.0",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@opentelemetry/instrumentation-http": "0.214.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.7.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.0.2",
    "jsdom": "^28.1.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
