# Auto-detect text files and normalize line endings
* text=auto

# Force LF for web files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Mark generated files
package-lock.json linguist-generated=true

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
