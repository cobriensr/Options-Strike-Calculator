# Repo-root .dockerignore — keeps ml-sweep + daemon builds small by
# excluding everything not needed inside the container. ml-sweep and
# daemon both use this root-directory build context; sidecar still
# builds from its own sidecar/ subdir.
#
# Note: each service's Dockerfile explicitly COPYs only the paths it
# needs. The ignore below is belt-and-suspenders: it strips large
# top-level trees before Railway uploads the build context, cutting
# upload time and image size.
#
# The three !src/... re-inclusions are for the daemon service, which
# imports a small set of shared modules from the main app's src/ tree
# (holiday calendar, trace-live timezone helper, GEX classification).
# Keeping them as a single source of truth avoids annual-drift bugs.

# Frontend + backend TypeScript — unused by ml-sweep
node_modules/
dist/
build/
coverage/
.next/
.vercel/
src/
!src/data/
src/data/*
!src/data/marketHours.ts
!src/utils/
src/utils/*
!src/utils/trace-live-tz.ts
!src/utils/gex-classification.ts
api/
public/
e2e/
playwright-report/
test-results/
scripts/

# Sidecar service (separate Railway service, own Dockerfile)
sidecar/

# Large ML artefacts that don't need to live in the image
ml/.venv/
ml/experiments/
ml/ml/experiments/
ml/plots/
ml/tests/
ml/data/
ml/trace/
ml/htmlcov/
ml/.pytest_cache/
ml/.ruff_cache/
ml/.coverage
ml/__pycache__/
ml/src/__pycache__/
ml/src/features/__pycache__/
ml/src/pac/__pycache__/
ml/src/options_features/__pycache__/
ml/src/pac_backtest/__pycache__/

# Docs + specs
docs/
pine/
*.md

# Git internals + CI
.git/
.github/
.claude/

# Dev config
.env*
.vscode/
.idea/
.DS_Store
tsconfig*.json
eslint.config.ts
vite.config.ts
vitest.config.ts
playwright.config.ts
package.json
package-lock.json

# Temporary comparison output files from Pine validation
comparison-*.md
