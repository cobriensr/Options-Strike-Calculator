//@version=6
indicator('ETH + RTH Session VWAP', overlay = true)

sessionGroup = 'Sessions'
displayGroup = 'Display'

priceSource = input.source(hlc3, 'VWAP source')
timeZone = input.string('America/Chicago', 'Session timezone', group = sessionGroup)

ethSession = input.session(
     '1700-1600',
     'ETH session',
     tooltip = 'CME equity-index electronic session: 17:00 CT to 16:00 CT next day. Use 1700-0830 for overnight-only.',
     group = sessionGroup
)
ethDays = input.string(
     '12345',
     'ETH session days (start day)',
     tooltip = '1 = Sunday, 7 = Saturday. Default = Sun–Thu starts (Sun eve through Fri close).',
     group = sessionGroup
)
rthSession = input.session(
     '0830-1500',
     'RTH session',
     tooltip = 'Default is regular U.S. equity/index trading hours in CT (08:30–15:00), Monday through Friday.',
     group = sessionGroup
)
rthDays = input.string(
     '23456',
     'RTH days',
     tooltip = '1 = Sunday, 7 = Saturday. Default covers Monday through Friday.',
     group = sessionGroup
)

showEth = input.bool(true, 'Show ETH VWAP', group = displayGroup)
showRth = input.bool(true, 'Show RTH VWAP', group = displayGroup)
ethColor = input.color(color.new(color.aqua, 0), 'ETH color', group = displayGroup)
rthColor = input.color(color.new(color.orange, 0), 'RTH color', group = displayGroup)

ethString = ethSession + ':' + ethDays
rthString = rthSession + ':' + rthDays

isInEth = not na(time(timeframe.period, ethString, timeZone))
isInRth = not na(time(timeframe.period, rthString, timeZone))

// Robust ETH-start anchor: build a per-day session ID that rolls over at 17:00 CT.
// Survives the 16:00–17:00 CT daily settlement break (no bars in that hour on most
// charts) and the Fri-16:00 → Sun-17:00 weekly break, both of which break the naive
// "previous bar outside session" pattern.
ctHour  = hour(time, timeZone)
ctDay   = dayofmonth(time, timeZone)
ctMonth = month(time, timeZone)
ctYear  = year(time, timeZone)
ethSessionId = ctHour < 17
     ? timestamp(timeZone, ctYear, ctMonth, ctDay, 0, 0) - 86400000
     : timestamp(timeZone, ctYear, ctMonth, ctDay, 0, 0)

ethSessionChanged = ta.change(ethSessionId) != 0
isEthStart = isInEth and (bar_index == 0 or ethSessionChanged)
isRthStart = isInRth and (bar_index == 0 or not isInRth[1])

var float ethPriceVolume = na
var float ethVolume = na
var float rthPriceVolume = na
var float rthVolume = na

priceVolume = nz(priceSource) * nz(volume)
vol = nz(volume)

if isEthStart
    ethPriceVolume := priceVolume
    ethVolume := vol
else if isInEth
    ethPriceVolume := nz(ethPriceVolume) + priceVolume
    ethVolume := nz(ethVolume) + vol
else
    ethPriceVolume := na
    ethVolume := na

if isRthStart
    rthPriceVolume := priceVolume
    rthVolume := vol
else if isInRth
    rthPriceVolume := nz(rthPriceVolume) + priceVolume
    rthVolume := nz(rthVolume) + vol
else
    rthPriceVolume := na
    rthVolume := na

ethVwap = ethVolume > 0 ? ethPriceVolume / ethVolume : na
rthVwap = rthVolume > 0 ? rthPriceVolume / rthVolume : na

plot(showEth ? ethVwap : na, 'ETH VWAP', color = ethColor, linewidth = 2)
plot(showRth ? rthVwap : na, 'RTH VWAP', color = rthColor, linewidth = 2)
