//@version=6
// =============================================================================
// PAC Backtest Config A — BOS Breakout (charting indicator only, no alerts)
// =============================================================================
// E1.5 deliverable from docs/superpowers/specs/pac-backtester-2026-04-18.md.
//
// Backtested config (2022-2024 NQ 1m, 2,729 trades, 89.7% WR, $89K P&L, 36/36
// positive months) ported as a visual-only indicator. NO alertcondition() calls
// on purpose — this is for manual eyeball validation on live charts BEFORE any
// automation.
//
// Strategy semantics:
//   entry_trigger:      BOS_BREAKOUT    (price closes beyond prior swing extreme)
//   exit_trigger:       ATR_TARGET      (2.0 × ATR(14) from entry)
//   stop_placement:     SWING_EXTREME   (most recent correct-side swing)
//   session:            RTH             (08:30–15:00 CT)
//   stop_atr_multiple:  2.25            (fallback when no correct-side swing)
//   target_atr_multiple:2.0
//   min_z_entry_vwap:   1.0             (signed by direction)
//   event_day_filter:   skip_events     (FOMC + OPEX — toggle input)
//
// Plots:
//   - Entry arrow (up/down triangle) at the BOS bar, next-bar-open fill
//   - Horizontal stop line from entry bar to target/stop hit or session end
//   - Horizontal target line (2.0 × ATR away from entry)
//   - Info label with direction / z_vwap / ADX / session at entry
//   - Background tint on event days (trades are suppressed)
//
// Install: TradingView → Pine Editor → paste → Save → Add to chart.
// Chart requirements: NQ 1-minute bars, RTH shown.
// =============================================================================

indicator(
  title="PAC BOS Config A — Charting Only",
  shorttitle="PAC BOS A",
  overlay=true,
  max_lines_count=500,
  max_labels_count=500,
  max_boxes_count=100
)

// ============================ INPUTS ============================

grp_core = "Core Strategy"
swingLen = input.int(5, "Swing Length (bars before/after)", minval=2, maxval=20, group=grp_core,
                    tooltip="Matches backtest swing_length=5. Pine's pivothigh/low requires swingLen bars of confirmation on each side — this intentionally matches the backtest's 5-bar causality fix.")
stopATRMult = input.float(2.25, "Stop × ATR(14)", step=0.25, group=grp_core)
targetATRMult = input.float(2.0, "Target × ATR(14)", step=0.25, group=grp_core)
minZVWAP = input.float(1.0, "Min |z_close_vwap|", step=0.1, group=grp_core,
                      tooltip="Long requires z > +1.0, short requires z < -1.0. Filters entries that aren't yet decisively on-side vs VWAP.")

grp_filter = "Filters"
useRTHOnly = input.bool(true, "Entries only in RTH (08:30–15:00 CT)", group=grp_filter)
skipEvents = input.bool(true, "Skip FOMC + OPEX days", group=grp_filter,
                       tooltip="OPEX = 3rd Friday of each month. FOMC dates are 2024-2026 hardcoded.")

grp_visual = "Visuals"
showLines = input.bool(true, "Show stop + target lines", group=grp_visual)
showLabels = input.bool(true, "Show entry info labels", group=grp_visual)
showADX = input.bool(true, "Show ADX(14) in info label", group=grp_visual)

grp_alerts = "Alerts"
useAlerts = input.bool(true, "Fire JSON webhook + sound alerts", group=grp_alerts,
                      tooltip="Fires a single dynamic alert() per signal. Configure the delivery in the TradingView alert dialog: Webhook URL + Play sound.")
alertStrategyId = input.string("pac_bos_config_a", "Strategy ID (in webhook JSON)", group=grp_alerts)

// ============================ SESSION ============================
// Chart timezone should be set to America/Chicago for this to match the
// backtest cleanly. We compare in exchange time via `hour` / `minute`.

inRTH = not useRTHOnly or (
  // 08:30 <= CT time < 15:00
  (hour == 8 and minute >= 30) or
  (hour >= 9 and hour < 15)
)

// ============================ EVENT DAYS ============================
// OPEX = 3rd Friday of the month (day-of-month between 15 and 21, Friday)
isOpex = dayofweek == dayofweek.friday and dayofmonth >= 15 and dayofmonth <= 21

// FOMC: hardcoded 2024-2026 decision dates (second day of the 2-day meeting).
// Source: Federal Reserve calendar. Update annually.
y = year
m = month
d = dayofmonth
isFOMC_2024 = (y == 2024) and (
  (m == 1 and d == 31) or (m == 3 and d == 20) or (m == 5 and d == 1) or
  (m == 6 and d == 12) or (m == 7 and d == 31) or (m == 9 and d == 18) or
  (m == 11 and d == 7)  or (m == 12 and d == 18)
)
isFOMC_2025 = (y == 2025) and (
  (m == 1 and d == 29) or (m == 3 and d == 19) or (m == 5 and d == 7) or
  (m == 6 and d == 18) or (m == 7 and d == 30) or (m == 9 and d == 17) or
  (m == 10 and d == 29) or (m == 12 and d == 10)
)
isFOMC_2026 = (y == 2026) and (
  (m == 1 and d == 28) or (m == 3 and d == 18) or (m == 4 and d == 29) or
  (m == 6 and d == 17) or (m == 7 and d == 29) or (m == 9 and d == 16) or
  (m == 10 and d == 28) or (m == 12 and d == 9)
)
isFOMC = isFOMC_2024 or isFOMC_2025 or isFOMC_2026
isEventDay = skipEvents and (isOpex or isFOMC)

// Faint background tint on event days so you can see what was excluded.
bgcolor(isEventDay ? color.new(color.orange, 92) : na, title="Event day skip")

// ============================ ATR ============================
atr14 = ta.atr(14)

// ============================ ADX (Wilder) ============================
// Pine's built-in ta.dmi requires di_len + adx_smoothing; we use 14 / 14.
[diplus, diminus, adx14] = ta.dmi(14, 14)

// ============================ VWAP + Z-SCORE ============================
// Session VWAP + rolling stdev of typical price within the session.
vwapVal = ta.vwap
// Cumulative typical-price stdev per session — reset at midnight.
tp = (high + low + close) / 3.0
tpSum = ta.cum(tp)
// A simple per-session std proxy: rolling std of (tp - vwap) — short window
// avoids session reset complexity while still reflecting intraday spread.
// 60 bars ~= 1 hour on 1m — long enough to smooth noise, short enough to
// track regime shifts.
sessionStdProxy = ta.stdev(tp - vwapVal, 60)
zClose = sessionStdProxy > 0 ? (close - vwapVal) / sessionStdProxy : 0.0

// ============================ SWING DETECTION ============================
// Pine's pivothigh(left, right) returns the pivot VALUE at the bar that is
// `right` bars AFTER the pivot — this is exactly the 5-bar confirmation lag
// we applied in the Python backtest. A swing "appears" on bar T only when
// bar T+5's data is available.

pivH = ta.pivothigh(swingLen, swingLen)
pivL = ta.pivotlow(swingLen, swingLen)

// Track the most recent confirmed swing high/low.
var float lastSwingHighLevel = na
var float lastSwingLowLevel = na
var int   lastSwingHighBar = na
var int   lastSwingLowBar = na

if not na(pivH)
    lastSwingHighLevel := pivH
    lastSwingHighBar := bar_index - swingLen
if not na(pivL)
    lastSwingLowLevel := pivL
    lastSwingLowBar := bar_index - swingLen

// ============================ BOS DETECTION ============================
// Bullish BOS: current bar closes above the most recent confirmed swing high
// AND prior bar's close was at or below it. Bearish BOS is the mirror.

bosBull = not na(lastSwingHighLevel) and close > lastSwingHighLevel and close[1] <= lastSwingHighLevel
bosBear = not na(lastSwingLowLevel) and close < lastSwingLowLevel and close[1] >= lastSwingLowLevel

// ============================ ENTRY GATE ============================
// Long: bullish BOS + RTH + not event day + z_vwap > min threshold
// Short: bearish BOS + RTH + not event day + z_vwap < -threshold

longEntry = bosBull and inRTH and not isEventDay and zClose > minZVWAP
shortEntry = bosBear and inRTH and not isEventDay and zClose < -minZVWAP

// ============================ STOP PLACEMENT ============================
// SWING_EXTREME with correct-side guard. Walk back via already-tracked
// lastSwingLow (for longs) / lastSwingHigh (for shorts). If the correct-side
// swing is missing or on the wrong side of entry, fall back to N_ATR.

entryPrice = close  // backtest fills next-bar-open; close is a reasonable live proxy

getLongStop() =>
    candidate = not na(lastSwingLowLevel) ? lastSwingLowLevel : na
    if not na(candidate) and candidate < entryPrice
        candidate
    else
        entryPrice - stopATRMult * atr14

getShortStop() =>
    candidate = not na(lastSwingHighLevel) ? lastSwingHighLevel : na
    if not na(candidate) and candidate > entryPrice
        candidate
    else
        entryPrice + stopATRMult * atr14

// ============================ VISUALIZATION ============================
// Signal arrows
plotshape(longEntry, title="Long BOS", style=shape.triangleup,
          location=location.belowbar, color=color.new(color.green, 0),
          size=size.small, text="L")
plotshape(shortEntry, title="Short BOS", style=shape.triangledown,
          location=location.abovebar, color=color.new(color.red, 0),
          size=size.small, text="S")

// Stop + target lines per entry (held for 60 bars after entry or EOD)
if showLines and longEntry
    stopLvl = getLongStop()
    tgtLvl = entryPrice + targetATRMult * atr14
    line.new(bar_index, stopLvl, bar_index + 60, stopLvl,
             color=color.new(color.red, 30), width=1, style=line.style_dashed)
    line.new(bar_index, tgtLvl, bar_index + 60, tgtLvl,
             color=color.new(color.green, 30), width=1, style=line.style_dashed)

if showLines and shortEntry
    stopLvl = getShortStop()
    tgtLvl = entryPrice - targetATRMult * atr14
    line.new(bar_index, stopLvl, bar_index + 60, stopLvl,
             color=color.new(color.red, 30), width=1, style=line.style_dashed)
    line.new(bar_index, tgtLvl, bar_index + 60, tgtLvl,
             color=color.new(color.green, 30), width=1, style=line.style_dashed)

// Entry info labels
if showLabels and (longEntry or shortEntry)
    lblTxt = (longEntry ? "LONG BOS" : "SHORT BOS") +
             "\nz_vwap: " + str.tostring(zClose, "#.##") +
             (showADX ? "\nADX: " + str.tostring(adx14, "#.#") : "") +
             "\nATR: " + str.tostring(atr14, "#.##")
    label.new(bar_index, longEntry ? low - atr14 * 0.3 : high + atr14 * 0.3,
              lblTxt,
              color=color.new(longEntry ? color.green : color.red, 80),
              textcolor=color.white,
              style=longEntry ? label.style_label_up : label.style_label_down,
              size=size.small)

// ============================ ALERTS ============================
// Two mechanisms, both fire when a LONG or SHORT BOS entry passes all filters:
//
//  1. `alert()` — dynamic JSON payload. Configure ONE alert in TradingView's
//     alert dialog using "Any alert() function call". Paste your webhook URL,
//     check "Play sound" + pick your sound. One alert = both webhook + audio.
//     The JSON body gets POST'd to the webhook exactly as constructed below.
//
//  2. `alertcondition()` — static named templates. Create TWO separate alerts
//     via the TV alert dialog if you want independently-configurable channels
//     (e.g. webhook-only for longs, sound-only for shorts). These appear in
//     the alert dialog as "PAC BOS — LONG entry" and "PAC BOS — SHORT entry".

// Construct JSON payload for webhook. str.tostring with "%.4f" keeps price
// precision without excess digits. {{ticker}} + {{time}} are TV placeholders
// that TradingView substitutes in the delivered message body.
makeWebhookJSON(action) =>
    stopLvl = action == "long" ? getLongStop() : getShortStop()
    tgtLvl = action == "long" ?
      entryPrice + targetATRMult * atr14 :
      entryPrice - targetATRMult * atr14
    '{' +
      '"strategy":"' + alertStrategyId + '",' +
      '"symbol":"{{ticker}}",' +
      '"action":"' + action + '",' +
      '"price":' + str.tostring(close, "#.####") + ',' +
      '"stop":' + str.tostring(stopLvl, "#.####") + ',' +
      '"target":' + str.tostring(tgtLvl, "#.####") + ',' +
      '"z_vwap":' + str.tostring(zClose, "#.##") + ',' +
      '"adx":' + str.tostring(adx14, "#.##") + ',' +
      '"atr":' + str.tostring(atr14, "#.####") + ',' +
      '"time":"{{time}}"' +
    '}'

if useAlerts and longEntry
    alert(makeWebhookJSON("long"), alert.freq_once_per_bar_close)
if useAlerts and shortEntry
    alert(makeWebhookJSON("short"), alert.freq_once_per_bar_close)

// Static named templates — create these in the TV alert dialog by picking
// "PAC BOS Config A" in the Condition dropdown, then the alert name below.
alertcondition(longEntry,
               title="PAC BOS — LONG entry",
               message="PAC BOS LONG on {{ticker}} @ {{close}}")
alertcondition(shortEntry,
               title="PAC BOS — SHORT entry",
               message="PAC BOS SHORT on {{ticker}} @ {{close}}")

// ============================ INFO TABLE ============================
// Persistent top-right table showing current-bar filter state.

var table t = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 70),
                        border_width=1, border_color=color.gray)
if barstate.islast
    table.cell(t, 0, 0, "In RTH",   text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, inRTH ? "YES" : "NO", text_color=inRTH ? color.green : color.red, text_size=size.small)
    table.cell(t, 0, 1, "Event Day", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 1, isEventDay ? "SKIP" : "OK", text_color=isEventDay ? color.orange : color.green, text_size=size.small)
    table.cell(t, 0, 2, "z_vwap",   text_color=color.white, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(zClose, "#.##"),
               text_color=math.abs(zClose) > minZVWAP ? color.green : color.gray,
               text_size=size.small)
    table.cell(t, 0, 3, "ADX(14)",  text_color=color.white, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(adx14, "#.#"), text_color=adx14 > 25 ? color.green : color.gray, text_size=size.small)
    table.cell(t, 0, 4, "ATR(14)",  text_color=color.white, text_size=size.small)
    table.cell(t, 1, 4, str.tostring(atr14, "#.##"), text_color=color.white, text_size=size.small)

// ============================ NOTES ============================
// What's simplified vs the Python backtest:
//   1. No on_opposite_signal handling — this is a charting indicator, not a
//      backtest engine. You manage active trades manually.
//   2. No exit_after_n_bos counter — same reason.
//   3. session_vwap_and_std uses a 60-bar rolling stdev proxy. The backtest
//      uses cumulative session-reset std. In practice the two track closely
//      within 30 minutes of the open; divergent in the first 30 minutes of
//      RTH. If you see signals firing pre-10:00 CT with questionable z_vwap,
//      that's probably this approximation — not a fundamental issue.
//   4. FOMC dates are hardcoded through 2026. Extend for 2027+ when the Fed
//      releases the calendar.
//
// What's faithful to the backtest:
//   - 5-bar swing confirmation lag (pivothigh/low(5,5) matches shift(5))
//   - Correct-side swing stop with N_ATR fallback
//   - RTH-only, event-day filter, z_vwap directional check
//   - Same ATR(14) and ADX(14) definitions
