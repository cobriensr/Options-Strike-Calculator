//@version=6
// =============================================================================
// PAC Backtest Config B — BOS Breakout + OPPOSITE_CHOCH exit
// =============================================================================
// E1.5 deliverable from docs/superpowers/specs/pac-backtester-2026-04-18.md.
//
// Backtested comparison (2022-2024 NQ 1m, post-causality-fix, stressed costs):
//   Config A (ATR_TARGET 2.0):  2729 trades, 89.7% WR, $32.65 avg, $89K total
//   Config B (OPPOSITE_CHOCH):  1840 trades, 88.5% WR, $59.45 avg, $109K total  ← DEFAULT
//   Config C (OPPOSITE_BOS):    1707 trades, 68.8% WR, $42.37 avg, $72K total
//   Config D (ATR_TARGET 4.0):  2199 trades, 74.9% WR, $41.58 avg, $91K total
//
// Config B wins: highest total P&L (+23% vs A), barely-worse WR, 82% larger
// avg trade, and only 14 stop-hits across 1840 trades (vs 230 in Config A).
// OPPOSITE_CHOCH exits capture more of each trend move while still protecting
// via structural reversal detection. See
// docs/superpowers/specs/pac-exit-trigger-finding-2026-04-22.md.
//
// Strategy semantics (DEFAULT = Config B):
//   entry_trigger:      BOS_BREAKOUT     (price closes beyond prior swing extreme)
//   exit_trigger:       OPPOSITE_CHOCH   (exit on structural reversal — new LL
//                                         for long / new HH for short)
//   stop_placement:     SWING_EXTREME    (most recent correct-side swing)
//   session:            RTH              (08:30–15:00 CT)
//   stop_atr_multiple:  2.25             (fallback when no correct-side swing)
//   min_z_entry_vwap:   1.0              (signed by direction)
//   event_day_filter:   skip_events      (FOMC + OPEX — toggle input)
//
// `Exit Mode` input toggles between OPPOSITE_CHOCH (default, matches Config B)
// and ATR_TARGET (2.0 × ATR, matches Config A). Both are kept so you can
// eyeball the difference live.
//
// Plots:
//   - Entry arrow (up/down triangle) at the BOS bar, next-bar-open fill
//   - Horizontal stop line from entry bar to exit
//   - Horizontal target/CHoCH-exit line that extends while in trade
//   - Info label with direction / z_vwap / ADX / session at entry
//   - Swing high/low markers + BOS break lines (always-on structure view)
//   - Background tint on event days (trades are suppressed)
//   - Exit markers (TARGET/STOP/OPP/EOD/CHOCH) with $ P&L per 1 contract
//
// Install: TradingView → Pine Editor → paste → Save → Add to chart.
// Chart requirements: NQ 1-minute bars, RTH shown.
// =============================================================================

indicator(title="PAC BOS Config B — Charting Only", shorttitle="PAC BOS B", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=100)

// ============================ INPUTS ============================

grp_core = "Core Strategy"
exitMode = input.string("OPPOSITE_CHOCH", "Exit Mode", options=["OPPOSITE_CHOCH", "ATR_TARGET"], group=grp_core, tooltip="OPPOSITE_CHOCH = Config B (let winners run, exit on structural reversal). ATR_TARGET = Config A (hard TP at N × ATR). Config B backtested +23% total P&L and 93% fewer stop hits.")
swingLen = input.int(5, "Swing Length (bars before/after)", minval=2, maxval=20, group=grp_core, tooltip="Matches backtest swing_length=5. Pine's pivothigh/low requires swingLen bars of confirmation on each side — this intentionally matches the backtest's 5-bar causality fix.")
stopATRMult = input.float(2.25, "Stop × ATR(14)", step=0.25, group=grp_core)
targetATRMult = input.float(2.0, "Target × ATR(14) (ATR_TARGET mode only)", step=0.25, group=grp_core)
minZVWAP = input.float(1.0, "Min |z_close_vwap|", step=0.1, group=grp_core, tooltip="Long requires z > +1.0, short requires z < -1.0. Filters entries that aren't yet decisively on-side vs VWAP.")
exitAfterNBos = input.int(2, "Exit after N same-direction BOS", minval=0, maxval=10, group=grp_core, tooltip="Config B uses 2 — exits when 2 same-direction BOS events print after entry (trend exhaustion). Set to 0 to disable.")

grp_filter = "Filters"
useRTHOnly = input.bool(true, "Entries only in RTH (08:30–15:00 CT)", group=grp_filter)
skipEvents = input.bool(true, "Skip FOMC + OPEX days", group=grp_filter, tooltip="OPEX = 3rd Friday of each month. FOMC dates are 2024-2026 hardcoded.")

grp_visual = "Visuals"
showLines = input.bool(true, "Show stop + target lines", group=grp_visual)
showLabels = input.bool(true, "Show entry info labels", group=grp_visual)
showADX = input.bool(true, "Show ADX(14) in info label", group=grp_visual)
showSwings = input.bool(true, "Show swing high/low markers", group=grp_visual)
showBOSLines = input.bool(true, "Show BOS break-level lines", group=grp_visual)
showExits = input.bool(true, "Show exit markers (CHOCH/TARGET/STOP/OPP/BOS2/EOD)", group=grp_visual)
showIgnoredSignals = input.bool(false, "Show hollow arrows for ignored signals", group=grp_visual, tooltip="When a BOS entry signal fires but the strategy is already in a trade, show a faded triangle so you can see what was ignored. Off by default to keep the chart clean.")

grp_alerts = "Alerts"
useAlerts = input.bool(true, "Fire JSON webhook + sound alerts", group=grp_alerts, tooltip="Fires a single dynamic alert() per signal. Configure the delivery in the TradingView alert dialog: Webhook URL + Play sound.")
alertStrategyId = input.string("pac_bos_config_b", "Strategy ID (in webhook JSON)", group=grp_alerts)

// ============================ SESSION ============================
// Use time(..., session_string, timezone) so the RTH check is independent of
// the chart's display timezone. "0830-1500:23456" = Mon-Fri 08:30-15:00 in
// the specified timezone. Returns the opening timestamp of the session when
// the current bar is in-session, else na.
rthSession = time(timeframe.period, "0830-1500:23456", "America/Chicago")
inRTH = not useRTHOnly or not na(rthSession)

// ============================ EVENT DAYS ============================
// OPEX = 3rd Friday of the month (day-of-month between 15 and 21, Friday)
isOpex = dayofweek == dayofweek.friday and dayofmonth >= 15 and dayofmonth <= 21

// FOMC: hardcoded 2024-2026 decision dates (second day of the 2-day meeting).
// Source: Federal Reserve calendar. Update annually.
y = year
m = month
d = dayofmonth
isFOMC_2024 = (y == 2024) and ((m == 1 and d == 31) or (m == 3 and d == 20) or (m == 5 and d == 1) or (m == 6 and d == 12) or (m == 7 and d == 31) or (m == 9 and d == 18) or (m == 11 and d == 7) or (m == 12 and d == 18))
isFOMC_2025 = (y == 2025) and ((m == 1 and d == 29) or (m == 3 and d == 19) or (m == 5 and d == 7) or (m == 6 and d == 18) or (m == 7 and d == 30) or (m == 9 and d == 17) or (m == 10 and d == 29) or (m == 12 and d == 10))
isFOMC_2026 = (y == 2026) and ((m == 1 and d == 28) or (m == 3 and d == 18) or (m == 4 and d == 29) or (m == 6 and d == 17) or (m == 7 and d == 29) or (m == 9 and d == 16) or (m == 10 and d == 28) or (m == 12 and d == 9))
isFOMC = isFOMC_2024 or isFOMC_2025 or isFOMC_2026
isEventDay = skipEvents and (isOpex or isFOMC)

// Faint background tint on event days so you can see what was excluded.
bgcolor(isEventDay ? color.new(color.orange, 92) : na, title="Event day skip")

// ============================ ATR ============================
atr14 = ta.atr(14)

// ============================ ADX (Wilder) ============================
// Pine's built-in ta.dmi requires di_len + adx_smoothing; we use 14 / 14.
[diplus, diminus, adx14] = ta.dmi(14, 14)

// ============================ VWAP + Z-SCORE ============================
// Session VWAP + rolling stdev of typical price within the session.
vwapVal = ta.vwap
// Cumulative typical-price stdev per session — reset at midnight.
tp = (high + low + close) / 3.0
// z_close_vwap MUST match the Python backtest
// (ml/src/pac/order_blocks.py:_session_vwap_std):
//   session_std = stdev of typical-price (H+L+C)/3 expanding since UTC midnight
//   z_close     = (close - session_vwap) / session_std
// The earlier rolling-60-bar stdev of (tp - vwap) fires FALSE z>1 at 08:30 CT
// because the window is overnight low-vol bars — Python's cumulative UTC-day
// stdev is larger at RTH open and correctly rejects those entries. This was
// the primary cause of the 2.8× trade-count inflation vs Python in the
// 2026-04-18 trade-level diff.
var float tpSum = 0.0
var float tpSumSq = 0.0
var int tpN = 0
utcDayOfMonth = dayofmonth(time, "UTC")
utcDayOfMonthPrev = nz(utcDayOfMonth[1], utcDayOfMonth)
isNewUTCDay = utcDayOfMonth != utcDayOfMonthPrev
if isNewUTCDay or bar_index == 0
    tpSum := 0.0
    tpSumSq := 0.0
    tpN := 0
tpSum := tpSum + tp
tpSumSq := tpSumSq + tp * tp
tpN := tpN + 1
// Sample stdev (ddof=1) to match pandas .std() default used in Python engine.
meanTp = tpN > 0 ? tpSum / tpN : 0.0
sessionVariance = tpN > 1 ? math.max(0.0, (tpSumSq - tpN * meanTp * meanTp) / (tpN - 1)) : 0.0
sessionStd = math.sqrt(sessionVariance)
zClose = sessionStd > 0 ? (close - vwapVal) / sessionStd : 0.0

// ============================ SWING DETECTION ============================
// Pine's pivothigh(left, right) returns the pivot VALUE at the bar that is
// `right` bars AFTER the pivot — this is exactly the 5-bar confirmation lag
// we applied in the Python backtest. A swing "appears" on bar T only when
// bar T+5's data is available.

pivH = ta.pivothigh(swingLen, swingLen)
pivL = ta.pivotlow(swingLen, swingLen)

// Track the most recent confirmed swing high/low.
var float lastSwingHighLevel = na
var float lastSwingLowLevel = na
var int   lastSwingHighBar = na
var int   lastSwingLowBar = na

// Bounded swing history for walk-back stop placement — mirrors Python's
// `_find_swing_stop_level` (ml/src/pac_backtest/loop.py).
var array<float> swingLowHistory = array.new_float()
var array<float> swingHighHistory = array.new_float()
SWING_HISTORY_CAP = 50

if not na(pivH)
    lastSwingHighLevel := pivH
    lastSwingHighBar := bar_index - swingLen
    array.push(swingHighHistory, pivH)
    if array.size(swingHighHistory) > SWING_HISTORY_CAP
        array.shift(swingHighHistory)
if not na(pivL)
    lastSwingLowLevel := pivL
    lastSwingLowBar := bar_index - swingLen
    array.push(swingLowHistory, pivL)
    if array.size(swingLowHistory) > SWING_HISTORY_CAP
        array.shift(swingLowHistory)

// Walk-back stop finders — iterate the swing history from most-recent to
// oldest, return the first level on the correct side of entry. Python's
// engine does this because the most-recent swing is often on the WRONG side
// of entry (BOS bars frequently coincide with an opposite-side pivot).
findLongStop(entryPx, atrVal) =>
    float result = na
    n = array.size(swingLowHistory)
    if n > 0
        for i = n - 1 to 0
            level = array.get(swingLowHistory, i)
            if level < entryPx
                result := level
                break
    na(result) ? entryPx - stopATRMult * atrVal : result

findShortStop(entryPx, atrVal) =>
    float result = na
    n = array.size(swingHighHistory)
    if n > 0
        for i = n - 1 to 0
            level = array.get(swingHighHistory, i)
            if level > entryPx
                result := level
                break
    na(result) ? entryPx + stopATRMult * atrVal : result

// ============================ BOS DETECTION ============================
// Bullish BOS: current bar closes above the most recent confirmed swing high
// AND prior bar's close was at or below it. Bearish BOS is the mirror.

bosBull = not na(lastSwingHighLevel) and close > lastSwingHighLevel and close[1] <= lastSwingHighLevel
bosBear = not na(lastSwingLowLevel) and close < lastSwingLowLevel and close[1] >= lastSwingLowLevel

// ============================ CHoCH DETECTION (simplified) ============================
// CHoCH = Change of Character. In LuxAlgo PAC / smc semantics: a new lower-low
// (after a series of higher-lows) or a new higher-high (after lower-highs) —
// structurally signals a potential trend change.
//
// This Pine approximation tracks the two most recent swing lows and the two
// most recent swing highs; a bearish CHoCH fires when a NEW confirmed swing
// LOW is below the PRIOR confirmed swing low (making-lower-lows), bullish
// CHoCH when a new swing HIGH is above the prior one (making-higher-highs).
//
// This is less strict than smc's 4-swing pattern matcher but captures the
// core intent: "first structural reversal after a trend". In the Python
// backtest, this produced the 88.5% WR / $59.45 avg / $109K 3-yr Config B
// result — 23% better than Config A's hard-TP approach.

var float prevSwingLowLevel = na
var float prevSwingHighLevel = na

if not na(pivL)
    prevSwingLowLevel := lastSwingLowLevel[1]
if not na(pivH)
    prevSwingHighLevel := lastSwingHighLevel[1]

chochBear = not na(pivL) and not na(prevSwingLowLevel) and pivL < prevSwingLowLevel
chochBull = not na(pivH) and not na(prevSwingHighLevel) and pivH > prevSwingHighLevel

// ============================ ENTRY GATE ============================
// Long: bullish BOS + RTH + not event day + z_vwap > min threshold
// Short: bearish BOS + RTH + not event day + z_vwap < -threshold

longEntry = bosBull and inRTH and not isEventDay and zClose > minZVWAP
shortEntry = bosBear and inRTH and not isEventDay and zClose < -minZVWAP

// ============================ STOP PLACEMENT ============================
// SWING_EXTREME via walk-back through swing history. Matches the Python
// engine which cannot blindly use the most-recent swing — BOS bars often
// coincide with an opposite-side pivot, planting the stop on the profit
// side of entry. findLongStop / findShortStop (defined above) iterate the
// swing arrays from newest to oldest to find the first correct-side level,
// falling back to N_ATR if none exists within the 50-swing lookback.

entryPrice = close  // backtest fills next-bar-open; close is a reasonable live proxy

getLongStop() => findLongStop(entryPrice, atr14)
getShortStop() => findShortStop(entryPrice, atr14)

// ============================ STRUCTURE MARKERS ============================
// Swing highs/lows: plot at the confirmed swing bar. pivothigh(N, N) reports
// the value at the bar that is N bars AFTER the swing — so offset=-swingLen
// moves the marker back to the actual swing bar. Dynamic offset tracks the
// swingLen input if the user changes it.
swingOffset = -swingLen
plotshape(showSwings and not na(pivH), title="Swing High", style=shape.circle, location=location.abovebar, color=color.new(color.red, 40), size=size.tiny, offset=swingOffset)
plotshape(showSwings and not na(pivL), title="Swing Low", style=shape.circle, location=location.belowbar, color=color.new(color.green, 40), size=size.tiny, offset=swingOffset)

// BOS break-level lines: when a BOS fires, draw the broken swing level as a
// horizontal blue line from the swing bar to the BOS bar. This is the key
// structural event the strategy is trading off.
if showBOSLines and bosBull
    line.new(lastSwingHighBar, lastSwingHighLevel, bar_index, lastSwingHighLevel, color=color.new(color.blue, 30), width=2, style=line.style_solid)
if showBOSLines and bosBear
    line.new(lastSwingLowBar, lastSwingLowLevel, bar_index, lastSwingLowLevel, color=color.new(color.blue, 30), width=2, style=line.style_solid)

// ============================ ACTIVE TRADE STATE DECLARATIONS ============================
// Declared up here (before the visualization block) so `openDir` is in scope
// for the willOpenLong/willOpenShort booleans below. The `var` keyword makes
// these persist across bars with initial values applied only on the first bar.
var int openDir = 0
var float openEntry = na
var float openStop = na
var float openTarget = na
var int openEntryBar = na
var line openStopLine = na
var line openTargetLine = na
var int bosCountSinceEntry = 0

// ============================ VISUALIZATION ============================
// Split entry signals into "actual entries" (state machine will open a new
// trade) vs "ignored signals" (strategy is already in a trade, so the
// signal is recorded but not acted on). Solid triangles = taken trades.
// Hollow triangles (optional) = signals the strategy chose to ignore.
//
// Reads openDir BEFORE the state machine block runs below, so it reflects
// the previous bar's end-of-bar state. If we were flat → willOpen fires.
// If we were already in a trade → signalIgnored fires instead.

willOpenLong = longEntry and openDir == 0
willOpenShort = shortEntry and openDir == 0
signalIgnoredLong = longEntry and openDir != 0
signalIgnoredShort = shortEntry and openDir != 0

// Solid: actual entries the strategy takes
plotshape(willOpenLong, title="Long Entry", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.small, text="L")
plotshape(willOpenShort, title="Short Entry", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.small, text="S")

// Hollow: signals that fired but strategy was already in a trade
plotshape(showIgnoredSignals and signalIgnoredLong, title="Long (ignored)", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 70), size=size.tiny)
plotshape(showIgnoredSignals and signalIgnoredShort, title="Short (ignored)", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 70), size=size.tiny)

// Entry info labels — only for ACTUAL entries (not ignored signals)
if showLabels and (willOpenLong or willOpenShort)
    dirTxt = willOpenLong ? "LONG BOS" : "SHORT BOS"
    adxPart = showADX ? "\nADX: " + str.tostring(adx14, "#.#") : ""
    lblTxt = dirTxt + "\nz_vwap: " + str.tostring(zClose, "#.##") + adxPart + "\nATR: " + str.tostring(atr14, "#.##")
    lblY = willOpenLong ? low - atr14 * 0.3 : high + atr14 * 0.3
    lblColor = color.new(willOpenLong ? color.green : color.red, 80)
    lblStyle = willOpenLong ? label.style_label_up : label.style_label_down
    label.new(bar_index, lblY, lblTxt, color=lblColor, textcolor=color.white, style=lblStyle, size=size.small)

// ============================ ACTIVE TRADE STATE MACHINE ============================
// All state vars declared up near the visualization block so willOpenLong/Short
// could reference openDir. Here we just run the state transitions.
//
// State (declared above):
//   openDir      : 0=flat, 1=long, -1=short
//   openEntry    : fill price at entry
//   openStop     : protective stop level
//   openTarget   : ATR target level
//   openStopLine : line.id of the currently-drawn stop line (so we can extend it)
//   openTargetLine : same for target
//   bosCountSinceEntry : counter for exit_after_n_bos rule

// Open a new long when longEntry fires and we're flat.
// Target line is only drawn in ATR_TARGET mode — in OPPOSITE_CHOCH mode there
// is no fixed target level; exit fires on structural reversal.
if showLines and longEntry and openDir == 0
    openDir := 1
    openEntry := close
    openStop := getLongStop()
    openTarget := close + targetATRMult * atr14
    openEntryBar := bar_index
    bosCountSinceEntry := 0
    openStopLine := line.new(bar_index, openStop, bar_index + 1, openStop, color=color.new(color.red, 20), width=2, style=line.style_dashed)
    if exitMode == "ATR_TARGET"
        openTargetLine := line.new(bar_index, openTarget, bar_index + 1, openTarget, color=color.new(color.green, 20), width=2, style=line.style_dashed)

// Open a new short when shortEntry fires and we're flat.
if showLines and shortEntry and openDir == 0
    openDir := -1
    openEntry := close
    openStop := getShortStop()
    openTarget := close - targetATRMult * atr14
    openEntryBar := bar_index
    bosCountSinceEntry := 0
    openStopLine := line.new(bar_index, openStop, bar_index + 1, openStop, color=color.new(color.red, 20), width=2, style=line.style_dashed)
    if exitMode == "ATR_TARGET"
        openTargetLine := line.new(bar_index, openTarget, bar_index + 1, openTarget, color=color.new(color.green, 20), width=2, style=line.style_dashed)

// Track same-direction BOS count post-entry (for exit_after_n_bos rule).
// Matches the Python backtest's `bos_count_since_entry` tracker in loop.py.
// `bar_index > openEntryBar` excludes the entry bar itself — the entry-bar
// BOS is what OPENED the trade and shouldn't count against it.
if openDir == 1 and bosBull and bar_index > openEntryBar
    bosCountSinceEntry := bosCountSinceEntry + 1
if openDir == -1 and bosBear and bar_index > openEntryBar
    bosCountSinceEntry := bosCountSinceEntry + 1

// Each bar while in a trade: extend stop line forward, and target line too
// if it was drawn (ATR_TARGET mode).
if openDir != 0 and not na(openStopLine)
    line.set_x2(openStopLine, bar_index)
    if not na(openTargetLine)
        line.set_x2(openTargetLine, bar_index)

// Exit detection: evaluate in priority order. Intrabar stop/target checks
// use high/low (backtest uses same convention). Opposite-signal + session-end
// checks at bar close, exit fills at close price.
//
// exitMode branch:
//   OPPOSITE_CHOCH → Config B: exit on structural reversal (chochBear for
//                    long trade, chochBull for short). TARGET check disabled.
//   ATR_TARGET     → Config A: exit on 2.0 × ATR fixed target. CHoCH ignored.

useChochExit = exitMode == "OPPOSITE_CHOCH"

// Stop + primary exit_trigger (CHoCH or ATR target)
hitLongStop = openDir == 1 and low <= openStop
hitShortStop = openDir == -1 and high >= openStop
hitLongTarget = not useChochExit and openDir == 1 and high >= openTarget
hitShortTarget = not useChochExit and openDir == -1 and low <= openTarget
chochExitLong = useChochExit and openDir == 1 and chochBear
chochExitShort = useChochExit and openDir == -1 and chochBull

// BoS counter — exit when N same-direction BOS events have printed post-entry.
// Matches Python backtest's `exit_after_n_bos` rule. Only checks if configured > 0.
bosCountExit = exitAfterNBos > 0 and openDir != 0 and bosCountSinceEntry >= exitAfterNBos

// Opposite-signal exit (EXIT_ONLY semantics). Uses RAW bosBear/bosBull rather
// than the fully-filtered shortEntry/longEntry — matches Python's detect_entry()
// which only checks the trigger, not session/z_vwap/event filters. This is the
// same-bar structural reversal signal that fires 30% of Config B's exits.
oppSignalLong = openDir == 1 and bosBear
oppSignalShort = openDir == -1 and bosBull

// Session-end forced flat
sessionEnded = openDir != 0 and inRTH[1] and not inRTH

// Exit reason priority order matches Python loop.py:
//   1. Intrabar stop (highest priority — stops are immediate)
//   2. Primary exit_trigger (ATR_TARGET or OPPOSITE_CHOCH)
//   3. BoS count exit (exit_after_n_bos rule)
//   4. Opposite-signal exit (on_opposite_signal = EXIT_ONLY)
//   5. Session end (lowest priority — only if nothing else exited)

exitReason = ""
exitPrice = 0.0
if hitLongStop or hitShortStop
    exitReason := "STOP"
    exitPrice := openStop
if exitReason == "" and (hitLongTarget or hitShortTarget)
    exitReason := "TARGET"
    exitPrice := openTarget
if exitReason == "" and (chochExitLong or chochExitShort)
    exitReason := "CHOCH"
    exitPrice := close
if exitReason == "" and bosCountExit
    exitReason := "BOS" + str.tostring(exitAfterNBos)
    exitPrice := close
if exitReason == "" and (oppSignalLong or oppSignalShort)
    exitReason := "OPP"
    exitPrice := close
if exitReason == "" and sessionEnded
    exitReason := "EOD"
    exitPrice := close

// Draw exit marker + clear state
if showExits and openDir != 0 and exitReason != ""
    exitWasWin = (openDir == 1 and exitPrice > openEntry) or (openDir == -1 and exitPrice < openEntry)
    markColor = exitWasWin ? color.new(color.green, 0) : color.new(color.red, 0)
    markY = openDir == 1 ? high + atr14 * 0.5 : low - atr14 * 0.5
    markTxt = exitReason + "\n$" + str.tostring((exitPrice - openEntry) * openDir, "#.##")
    label.new(bar_index, markY, markTxt, color=color.new(color.black, 50), textcolor=markColor, style=label.style_label_center, size=size.small)
    openDir := 0
    openEntry := na
    openStop := na
    openTarget := na
    openEntryBar := na
    openStopLine := na
    openTargetLine := na
    bosCountSinceEntry := 0

// ============================ ALERTS ============================
// Two mechanisms, both fire when a LONG or SHORT BOS entry passes all filters:
//
//  1. `alert()` — dynamic JSON payload. Configure ONE alert in TradingView's
//     alert dialog using "Any alert() function call". Paste your webhook URL,
//     check "Play sound" + pick your sound. One alert = both webhook + audio.
//     The JSON body gets POST'd to the webhook exactly as constructed below.
//
//  2. `alertcondition()` — static named templates. Create TWO separate alerts
//     via the TV alert dialog if you want independently-configurable channels
//     (e.g. webhook-only for longs, sound-only for shorts). These appear in
//     the alert dialog as "PAC BOS — LONG entry" and "PAC BOS — SHORT entry".

// Construct JSON payload for webhook. str.tostring with "%.4f" keeps price
// precision without excess digits. {{ticker}} + {{time}} are TV placeholders
// that TradingView substitutes in the delivered message body.
makeWebhookJSON(action) =>
    stopLvl = action == "long" ? getLongStop() : getShortStop()
    tgtLvl = action == "long" ? entryPrice + targetATRMult * atr14 : entryPrice - targetATRMult * atr14
    p1 = '{"strategy":"' + alertStrategyId + '","symbol":"{{ticker}}","action":"' + action + '"'
    p2 = ',"price":' + str.tostring(close, "#.####") + ',"stop":' + str.tostring(stopLvl, "#.####")
    p3 = ',"target":' + str.tostring(tgtLvl, "#.####") + ',"z_vwap":' + str.tostring(zClose, "#.##")
    p4 = ',"adx":' + str.tostring(adx14, "#.##") + ',"atr":' + str.tostring(atr14, "#.####")
    p5 = ',"time":"{{time}}"}'
    p1 + p2 + p3 + p4 + p5

// Alerts fire only on ACTUAL entries (willOpenLong/willOpenShort), not on
// every filtered signal. If a BOS fires during an active trade, no alert —
// that's a signal the state machine would ignore anyway.
if useAlerts and willOpenLong
    alert(makeWebhookJSON("long"), alert.freq_once_per_bar_close)
if useAlerts and willOpenShort
    alert(makeWebhookJSON("short"), alert.freq_once_per_bar_close)

// Static named templates — create these in the TV alert dialog by picking
// "PAC BOS Config B" in the Condition dropdown, then the alert name below.
alertcondition(willOpenLong, title="PAC BOS — LONG entry", message="PAC BOS LONG on {{ticker}} @ {{close}}")
alertcondition(willOpenShort, title="PAC BOS — SHORT entry", message="PAC BOS SHORT on {{ticker}} @ {{close}}")

// ============================ INFO TABLE ============================
// Persistent top-right table showing current-bar filter state.

var table t = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 70), border_width=1, border_color=color.gray)
if barstate.islast
    zColor = math.abs(zClose) > minZVWAP ? color.green : color.gray
    adxColor = adx14 > 25 ? color.green : color.gray
    rthColor = inRTH ? color.green : color.red
    evColor = isEventDay ? color.orange : color.green
    table.cell(t, 0, 0, "In RTH", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, inRTH ? "YES" : "NO", text_color=rthColor, text_size=size.small)
    table.cell(t, 0, 1, "Event Day", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 1, isEventDay ? "SKIP" : "OK", text_color=evColor, text_size=size.small)
    table.cell(t, 0, 2, "z_vwap", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(zClose, "#.##"), text_color=zColor, text_size=size.small)
    table.cell(t, 0, 3, "ADX(14)", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(adx14, "#.#"), text_color=adxColor, text_size=size.small)
    table.cell(t, 0, 4, "ATR(14)", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 4, str.tostring(atr14, "#.##"), text_color=color.white, text_size=size.small)

// ============================ NOTES ============================
// What's simplified vs the Python backtest:
//   1. No on_opposite_signal handling — this is a charting indicator, not a
//      backtest engine. You manage active trades manually.
//   2. No exit_after_n_bos counter — same reason.
//   3. session_vwap_and_std uses a 60-bar rolling stdev proxy. The backtest
//      uses cumulative session-reset std. In practice the two track closely
//      within 30 minutes of the open; divergent in the first 30 minutes of
//      RTH. If you see signals firing pre-10:00 CT with questionable z_vwap,
//      that's probably this approximation — not a fundamental issue.
//   4. FOMC dates are hardcoded through 2026. Extend for 2027+ when the Fed
//      releases the calendar.
//
// What's faithful to the backtest:
//   - 5-bar swing confirmation lag (pivothigh/low(5,5) matches shift(5))
//   - Correct-side swing stop with N_ATR fallback
//   - RTH-only, event-day filter, z_vwap directional check
//   - Same ATR(14) and ADX(14) definitions
