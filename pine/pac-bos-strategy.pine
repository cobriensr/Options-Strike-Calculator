//@version=6
// =============================================================================
// PAC Backtest Config B — STRATEGY version
// =============================================================================
// Strategy sibling of pac-bos.pine. TradingView Strategy Tester will compute
// net profit, drawdown, profit factor, Sharpe, trade list, equity curve.
//
// Run on MNQ1! 1m for results matching the Python backtest (tick_value $0.50).
// NQ1! works too — P&L scales 10× but WR/PF/drawdown ratios are identical.
//
// Cost model matches the stressed Python backtest:
//   initial_capital   = $25,000
//   commission        = $1.50/order  (= $3.00 round-trip)
//   slippage          = 1 tick/fill
//
// Config B defaults (best 5-variant exit sweep result):
//   entry       BOS_BREAKOUT
//   exit_trigger OPPOSITE_CHOCH  (toggleable to ATR_TARGET)
//   stop         SWING_EXTREME with 2.25 ATR fallback
//   z_vwap gate  1.0 signed-by-direction
//   exit_after_n_bos 2
// =============================================================================

strategy(title="PAC BOS Config B — Strategy", shorttitle="PAC BOS B Strat", overlay=true, pyramiding=0, default_qty_type=strategy.fixed, default_qty_value=1, initial_capital=25000, commission_type=strategy.commission.cash_per_order, commission_value=1.50, slippage=1, calc_on_every_tick=false, process_orders_on_close=false, max_lines_count=500, max_labels_count=500)

// ============================ INPUTS ============================

grp_core = "Core Strategy"
exitMode = input.string("OPPOSITE_CHOCH", "Exit Mode", options=["OPPOSITE_CHOCH", "ATR_TARGET"], group=grp_core, tooltip="OPPOSITE_CHOCH = Config B. ATR_TARGET = Config A.")
swingLen = input.int(5, "Swing Length", minval=2, maxval=20, group=grp_core)
stopATRMult = input.float(2.25, "Stop × ATR(14)", step=0.25, group=grp_core)
targetATRMult = input.float(2.0, "Target × ATR(14) (ATR_TARGET only)", step=0.25, group=grp_core)
minZVWAP = input.float(1.0, "Min |z_close_vwap|", step=0.1, group=grp_core, tooltip="Set to 0 to disable the VWAP z-score filter (diagnostic).")
exitAfterNBos = input.int(2, "Exit after N same-dir BOS", minval=0, maxval=10, group=grp_core, tooltip="Set to 0 to disable.")

grp_filter = "Filters"
useRTHOnly = input.bool(true, "Entries only in RTH (08:30–15:00 CT)", group=grp_filter)
skipEvents = input.bool(true, "Skip FOMC + OPEX days", group=grp_filter)

grp_visual = "Visuals"
showSwings = input.bool(true, "Show swing markers", group=grp_visual)
showBOSLines = input.bool(true, "Show BOS break lines", group=grp_visual)
showDiagnostic = input.bool(false, "Show filter diagnostic plots", group=grp_visual, tooltip="Plots zClose, inRTH, isEventDay on a separate pane so you can see why entries are/aren't firing.")

// ============================ SESSION (timezone-explicit) ============================
// Use hour(time, timezone) / minute(time, timezone) — these extract the CT-time
// components regardless of the chart's display timezone. More robust than
// relying on session strings which can silently mismatch.
ctHour = hour(time, "America/Chicago")
ctMin = minute(time, "America/Chicago")
inRTH = not useRTHOnly or ((ctHour == 8 and ctMin >= 30) or (ctHour >= 9 and ctHour < 15))

// ============================ EVENT DAYS ============================
isOpex = dayofweek == dayofweek.friday and dayofmonth >= 15 and dayofmonth <= 21
y = year
m = month
d = dayofmonth
isFOMC_2024 = (y == 2024) and ((m == 1 and d == 31) or (m == 3 and d == 20) or (m == 5 and d == 1) or (m == 6 and d == 12) or (m == 7 and d == 31) or (m == 9 and d == 18) or (m == 11 and d == 7) or (m == 12 and d == 18))
isFOMC_2025 = (y == 2025) and ((m == 1 and d == 29) or (m == 3 and d == 19) or (m == 5 and d == 7) or (m == 6 and d == 18) or (m == 7 and d == 30) or (m == 9 and d == 17) or (m == 10 and d == 29) or (m == 12 and d == 10))
isFOMC_2026 = (y == 2026) and ((m == 1 and d == 28) or (m == 3 and d == 18) or (m == 4 and d == 29) or (m == 6 and d == 17) or (m == 7 and d == 29) or (m == 9 and d == 16) or (m == 10 and d == 28) or (m == 12 and d == 9))
isFOMC = isFOMC_2024 or isFOMC_2025 or isFOMC_2026
isEventDay = skipEvents and (isOpex or isFOMC)

bgcolor(isEventDay ? color.new(color.orange, 92) : na, title="Event day skip")

// ============================ INDICATORS ============================
atr14 = ta.atr(14)
[diplus, diminus, adx14] = ta.dmi(14, 14)

vwapVal = ta.vwap
tp = (high + low + close) / 3.0
sessionStdProxy = ta.stdev(tp - vwapVal, 60)
zClose = sessionStdProxy > 0 ? (close - vwapVal) / sessionStdProxy : 0.0

// ============================ SWING + BOS + CHoCH ============================
pivH = ta.pivothigh(swingLen, swingLen)
pivL = ta.pivotlow(swingLen, swingLen)

var float lastSwingHighLevel = na
var float lastSwingLowLevel = na
var int lastSwingHighBar = na
var int lastSwingLowBar = na

if not na(pivH)
    lastSwingHighLevel := pivH
    lastSwingHighBar := bar_index - swingLen
if not na(pivL)
    lastSwingLowLevel := pivL
    lastSwingLowBar := bar_index - swingLen

bosBull = not na(lastSwingHighLevel) and close > lastSwingHighLevel and close[1] <= lastSwingHighLevel
bosBear = not na(lastSwingLowLevel) and close < lastSwingLowLevel and close[1] >= lastSwingLowLevel

var float prevSwingLowLevel = na
var float prevSwingHighLevel = na
if not na(pivL)
    prevSwingLowLevel := lastSwingLowLevel[1]
if not na(pivH)
    prevSwingHighLevel := lastSwingHighLevel[1]

chochBear = not na(pivL) and not na(prevSwingLowLevel) and pivL < prevSwingLowLevel
chochBull = not na(pivH) and not na(prevSwingHighLevel) and pivH > prevSwingHighLevel

// ============================ ENTRY GATE ============================
longEntry = bosBull and inRTH and not isEventDay and zClose > minZVWAP
shortEntry = bosBear and inRTH and not isEventDay and zClose < -minZVWAP

// ============================ STOP PLACEMENT ============================
// Stops use a FIXED entry reference (strategy.position_avg_price) once in a
// trade, so the stop doesn't drift bar-to-bar as in the prior version. This
// matches the Python backtest which places the stop ONCE at entry.
entryRefPrice = strategy.position_size != 0 and not na(strategy.position_avg_price) ? strategy.position_avg_price : close

getLongStopFrom(p) =>
    candidate = not na(lastSwingLowLevel) ? lastSwingLowLevel : na
    if not na(candidate) and candidate < p
        candidate
    else
        p - stopATRMult * atr14

getShortStopFrom(p) =>
    candidate = not na(lastSwingHighLevel) ? lastSwingHighLevel : na
    if not na(candidate) and candidate > p
        candidate
    else
        p + stopATRMult * atr14

// ============================ VISUAL MARKERS ============================
swingOffset = -swingLen
plotshape(showSwings and not na(pivH), title="Swing High", style=shape.circle, location=location.abovebar, color=color.new(color.red, 40), size=size.tiny, offset=swingOffset)
plotshape(showSwings and not na(pivL), title="Swing Low", style=shape.circle, location=location.belowbar, color=color.new(color.green, 40), size=size.tiny, offset=swingOffset)

if showBOSLines and bosBull
    line.new(lastSwingHighBar, lastSwingHighLevel, bar_index, lastSwingHighLevel, color=color.new(color.blue, 30), width=2, style=line.style_solid)
if showBOSLines and bosBear
    line.new(lastSwingLowBar, lastSwingLowLevel, bar_index, lastSwingLowLevel, color=color.new(color.blue, 30), width=2, style=line.style_solid)

// ============================ TRADE-ENTRY BAR TRACKING ============================
// Track the bar index of the current trade's entry via position-size transition.
// Avoids calling strategy.opentrades.entry_bar_index() which can runtime-error
// when there are no open trades.
var int tradeEntryBar = na
var int bosCountSinceEntry = 0

flatNow = strategy.position_size == 0
flatPrev = strategy.position_size[1] == 0
justEntered = not flatNow and flatPrev

if justEntered
    tradeEntryBar := bar_index
    bosCountSinceEntry := 0
if flatNow
    tradeEntryBar := na
    bosCountSinceEntry := 0

longPos = strategy.position_size > 0
shortPos = strategy.position_size < 0

// Count same-direction BOS events after the entry bar
if longPos and bosBull and not na(tradeEntryBar) and bar_index > tradeEntryBar
    bosCountSinceEntry := bosCountSinceEntry + 1
if shortPos and bosBear and not na(tradeEntryBar) and bar_index > tradeEntryBar
    bosCountSinceEntry := bosCountSinceEntry + 1

// ============================ STRATEGY ORDERS ============================
// ENTRY — fires when qualifying signal meets flat position. TV fills at next
// bar's open (default), matching the Python backtest's fill convention.
if longEntry and flatNow
    strategy.entry("Long", strategy.long)
if shortEntry and flatNow
    strategy.entry("Short", strategy.short)

// STOP + optional TARGET. Called every bar while in a trade; strategy.exit
// modifies the resting order each bar. Stops are computed from the fixed
// entry price (strategy.position_avg_price), so they don't drift.
if longPos
    longStopLvl = getLongStopFrom(entryRefPrice)
    longTgtLvl = exitMode == "ATR_TARGET" ? entryRefPrice + targetATRMult * atr14 : na
    strategy.exit("LongX", from_entry="Long", stop=longStopLvl, limit=longTgtLvl, comment_loss="STOP", comment_profit="TARGET")
if shortPos
    shortStopLvl = getShortStopFrom(entryRefPrice)
    shortTgtLvl = exitMode == "ATR_TARGET" ? entryRefPrice - targetATRMult * atr14 : na
    strategy.exit("ShortX", from_entry="Short", stop=shortStopLvl, limit=shortTgtLvl, comment_loss="STOP", comment_profit="TARGET")

// CHoCH market exit (OPPOSITE_CHOCH mode only)
if exitMode == "OPPOSITE_CHOCH" and longPos and chochBear
    strategy.close("Long", comment="CHOCH")
if exitMode == "OPPOSITE_CHOCH" and shortPos and chochBull
    strategy.close("Short", comment="CHOCH")

// BoS counter exit
if exitAfterNBos > 0 and longPos and bosCountSinceEntry >= exitAfterNBos
    strategy.close("Long", comment="BOS" + str.tostring(exitAfterNBos))
if exitAfterNBos > 0 and shortPos and bosCountSinceEntry >= exitAfterNBos
    strategy.close("Short", comment="BOS" + str.tostring(exitAfterNBos))

// Opposite-signal exit — uses raw bosBear/bosBull (no entry filters)
if longPos and bosBear
    strategy.close("Long", comment="OPP")
if shortPos and bosBull
    strategy.close("Short", comment="OPP")

// Session-end forced flat
sessionEnded = not flatNow and inRTH[1] and not inRTH
if sessionEnded
    strategy.close_all(comment="EOD")

// ============================ DIAGNOSTIC PLOTS (opt-in) ============================
// When `showDiagnostic` is on, plots key filter components so you can see
// exactly what's gating entries. Useful when strategy tester shows 0 trades.
//
// Values plotted (scaled to fit on chart y-axis):
//   - zClose (blue) — scaled by multiplying by ATR so it overlays near price
//   - inRTH indicator (green dashes when in session)
//   - longEntry / shortEntry trigger points (big triangles)
plotshape(showDiagnostic and longEntry, title="DIAG: longEntry", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.large, text="L-sig")
plotshape(showDiagnostic and shortEntry, title="DIAG: shortEntry", style=shape.triangledown, location=location.abovebar, color=color.new(color.fuchsia, 0), size=size.large, text="S-sig")
plotshape(showDiagnostic and inRTH and not inRTH[1], title="DIAG: RTH open", style=shape.arrowup, location=location.bottom, color=color.aqua, size=size.small, text="RTH")
