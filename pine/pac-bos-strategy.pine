//@version=6
// =============================================================================
// PAC Backtest Config B — STRATEGY version
// =============================================================================
// Strategy sibling of pac-bos.pine for TradingView's Strategy Tester.
//
// If the tester shows 0 trades:
//   1. Turn ON "Disable ALL filters (diagnostic)" → runs bare BOS logic only.
//      If THIS fires trades → one of the filters is blocking everything.
//      If THIS doesn't fire → issue is chart/data/account, not the script.
//   2. Turn ON "Show filter diagnostic plots" → plots raw longEntry/shortEntry
//      triangles so you can see if the filter pipeline computes TRUE at all.
//
// Run on MNQ1! 1m for results matching the Python backtest.
// =============================================================================

// IMPORTANT: `margin_long`/`margin_short` DEFAULT to 100 — meaning Pine requires
// 100% of notional value as cash before it will open a position. For MNQ1! at
// ~20,000 pts × $2/pt = ~$40,000 notional per contract, a $25K initial_capital
// with the default 100% margin means EVERY entry silently fails and the Strategy
// Tester shows 0 trades. Setting margin to 0.25% matches realistic broker
// day-trade margins (MNQ ≈ $100/contract, NQ ≈ $1,000/contract — both work out
// to 0.25% of notional at current prices) and lets 1-contract entries fit the
// $25K account with room to spare.
strategy(title="PAC BOS Config B — Strategy", shorttitle="PAC BOS B Strat", overlay=true, pyramiding=0, default_qty_type=strategy.fixed, default_qty_value=1, initial_capital=25000, commission_type=strategy.commission.cash_per_order, commission_value=1.50, slippage=1, margin_long=0.25, margin_short=0.25, max_lines_count=500, max_labels_count=500)

// ============================ INPUTS ============================

grp_diag = "Diagnostic"
disableAllFilters = input.bool(false, "Disable ALL filters (diagnostic)", group=grp_diag, tooltip="When ON, strips every filter (RTH, event-day, z_vwap, CHoCH exit, BoS counter) and runs bare BOS entries with a 2.25 ATR stop + 4.0 ATR target. If this fires trades but default settings don't, one of the filters is blocking.")
showDiagnostic = input.bool(false, "Show filter diagnostic plots", group=grp_diag, tooltip="Plots raw longEntry/shortEntry triangles before the state-gate check, so you can see if filters compute TRUE at all.")

grp_core = "Core Strategy"
exitMode = input.string("OPPOSITE_CHOCH", "Exit Mode", options=["OPPOSITE_CHOCH", "ATR_TARGET"], group=grp_core)
swingLen = input.int(5, "Swing Length", minval=2, maxval=20, group=grp_core)
stopATRMult = input.float(2.25, "Stop × ATR(14)", step=0.25, group=grp_core)
targetATRMult = input.float(2.0, "Target × ATR(14) (ATR_TARGET only)", step=0.25, group=grp_core)
minZVWAP = input.float(1.0, "Min |z_close_vwap|", step=0.1, group=grp_core)
exitAfterNBos = input.int(2, "Exit after N same-dir BOS", minval=0, maxval=10, group=grp_core)

grp_filter = "Filters"
useRTHOnly = input.bool(true, "Entries only in RTH (08:30–15:00 CT)", group=grp_filter)
skipEvents = input.bool(true, "Skip FOMC + OPEX days", group=grp_filter)

grp_visual = "Visuals"
showSwings = input.bool(true, "Show swing markers", group=grp_visual)
showBOSLines = input.bool(true, "Show BOS break lines", group=grp_visual)

// ============================ SESSION (timezone-explicit) ============================
ctHour = hour(time, "America/Chicago")
ctMin = minute(time, "America/Chicago")
rawInRTH = (ctHour == 8 and ctMin >= 30) or (ctHour >= 9 and ctHour < 15)
inRTH = disableAllFilters or not useRTHOnly or rawInRTH

// ============================ EVENT DAYS ============================
isOpex = dayofweek == dayofweek.friday and dayofmonth >= 15 and dayofmonth <= 21
y = year
m = month
d = dayofmonth
isFOMC_2024 = (y == 2024) and ((m == 1 and d == 31) or (m == 3 and d == 20) or (m == 5 and d == 1) or (m == 6 and d == 12) or (m == 7 and d == 31) or (m == 9 and d == 18) or (m == 11 and d == 7) or (m == 12 and d == 18))
isFOMC_2025 = (y == 2025) and ((m == 1 and d == 29) or (m == 3 and d == 19) or (m == 5 and d == 7) or (m == 6 and d == 18) or (m == 7 and d == 30) or (m == 9 and d == 17) or (m == 10 and d == 29) or (m == 12 and d == 10))
isFOMC_2026 = (y == 2026) and ((m == 1 and d == 28) or (m == 3 and d == 18) or (m == 4 and d == 29) or (m == 6 and d == 17) or (m == 7 and d == 29) or (m == 9 and d == 16) or (m == 10 and d == 28) or (m == 12 and d == 9))
isFOMC = isFOMC_2024 or isFOMC_2025 or isFOMC_2026
isEventDay = not disableAllFilters and skipEvents and (isOpex or isFOMC)

bgcolor(isEventDay ? color.new(color.orange, 92) : na, title="Event day skip")

// ============================ INDICATORS ============================
atr14 = ta.atr(14)
[diplus, diminus, adx14] = ta.dmi(14, 14)

tp = (high + low + close) / 3.0

// z_close_vwap MUST match the Python backtest EXACTLY. Python
// (ml/src/pac/order_blocks.py) computes BOTH the VWAP and the stdev with
// a UTC-midnight reset (ts_event.dt.floor("D")). Pine's built-in ta.vwap
// resets at the chart symbol's session boundary (globex 17:00 CT) — a
// ~2-hour mismatch vs Python that left a residual z-score divergence
// even after we fixed the stdev reset. The fix is to compute VWAP
// manually with the same UTC-midnight reset so numerator and denominator
// integrate over matching windows.
var float vwapNum = 0.0  // Σ tp × vol
var float vwapDen = 0.0  // Σ vol
var float tpSum = 0.0
var float tpSumSq = 0.0
var int tpN = 0
utcDayOfMonth = dayofmonth(time, "UTC")
utcDayOfMonthPrev = nz(utcDayOfMonth[1], utcDayOfMonth)
isNewUTCDay = utcDayOfMonth != utcDayOfMonthPrev
if isNewUTCDay or bar_index == 0
    vwapNum := 0.0
    vwapDen := 0.0
    tpSum := 0.0
    tpSumSq := 0.0
    tpN := 0
vwapNum := vwapNum + tp * volume
vwapDen := vwapDen + volume
tpSum := tpSum + tp
tpSumSq := tpSumSq + tp * tp
tpN := tpN + 1
vwapVal = vwapDen > 0 ? vwapNum / vwapDen : close
// Sample stdev (ddof=1) to match pandas .std() default used in Python engine
meanTp = tpN > 0 ? tpSum / tpN : 0.0
sessionVariance = tpN > 1 ? math.max(0.0, (tpSumSq - tpN * meanTp * meanTp) / (tpN - 1)) : 0.0
sessionStd = math.sqrt(sessionVariance)
zClose = sessionStd > 0 ? (close - vwapVal) / sessionStd : 0.0

// Effective minZVWAP applied to entries — 0 when diagnostic is on
effMinZVWAP = disableAllFilters ? 0.0 : minZVWAP
effExitMode = disableAllFilters ? "ATR_TARGET" : exitMode  // simpler exit when diagnosing
effExitAfterNBos = disableAllFilters ? 0 : exitAfterNBos
effTargetATR = disableAllFilters ? 4.0 : targetATRMult

// ============================ SWING + BOS + CHoCH (smc-compatible) ============================
// Ports `smartmoneyconcepts.swing_highs_lows()` semantics to Pine so swing
// detection stays in sync with the Python backtest. Pine's built-in
// ta.pivothigh(5,5) differs from smc in three material ways:
//   1. WINDOW: smc uses 10 bars asymmetric (high[i-4..i+5]) — literally
//      `high.shift(-5).rolling(10).max()` at row i. Pine's pivothigh uses
//      11 bars symmetric (high[i-5..i+5]).
//   2. EQUALITY: smc marks a swing when high[i] == max(window) — ties count.
//      Pine's pivothigh requires STRICT greater-than, missing ties.
//   3. PRIORITY: if both high and low conditions match the same bar, smc's
//      nested np.where prefers high. Pine's pivothigh + pivotlow are
//      independent and can fire both on the same bar.
// Plus smc has a DEDUP post-processing step: consecutive same-type swings
// (two highs in a row, or two lows) are collapsed to keep only the extreme
// one (higher high, lower low). We replicate this per-bar by replacing the
// last history entry when a same-type swing confirms before an opposite-type.
//
// This block was the last remaining source of ~105-vs-38 trade divergence
// vs the Python backtest — the pivothigh/pivotlow semantics caught BOS
// events on different bars than smc does.

windowLen = swingLen * 2
isSmcHighConfirm = high[swingLen] == ta.highest(high, windowLen)
isSmcLowConfirm = low[swingLen] == ta.lowest(low, windowLen)

// smc priority: check high first in the nested np.where
newSwingKind = isSmcHighConfirm ? 1 : isSmcLowConfirm ? -1 : 0
newSwingLevel = isSmcHighConfirm ? high[swingLen] : isSmcLowConfirm ? low[swingLen] : float(na)
newSwingBar = bar_index - swingLen

var float lastSwingHighLevel = na
var float lastSwingLowLevel = na
var int lastSwingHighBar = na
var int lastSwingLowBar = na
var int lastSwingKind = 0  // 1=last accepted swing was a high, -1=low, 0=none yet

// Bounded swing history for walk-back stop placement. Parallel `*Bars`
// arrays track WHEN each swing was confirmed so findLongStop/findShortStop
// can exclude pivots confirmed at the signal bar itself.
var array<float> swingLowHistory = array.new_float()
var array<int> swingLowHistoryBars = array.new_int()
var array<float> swingHighHistory = array.new_float()
var array<int> swingHighHistoryBars = array.new_int()
SWING_HISTORY_CAP = 50

// Per-bar dedup: if new swing is same-type as the last accepted one, it
// REPLACES the last one iff it's more extreme (higher for highs, lower
// for lows). Otherwise it's discarded. Ties favor the earlier swing, which
// matches smc's `highs >= next_highs` and `lows <= next_lows` rules.
float pivH = na
float pivL = na
replaceLast = false

if newSwingKind == 1
    if lastSwingKind == 1
        if newSwingLevel > lastSwingHighLevel
            pivH := newSwingLevel
            replaceLast := true
    else
        pivH := newSwingLevel
else if newSwingKind == -1
    if lastSwingKind == -1
        if newSwingLevel < lastSwingLowLevel
            pivL := newSwingLevel
            replaceLast := true
    else
        pivL := newSwingLevel

if not na(pivH)
    lastSwingHighLevel := pivH
    lastSwingHighBar := newSwingBar
    lastSwingKind := 1
    if replaceLast and array.size(swingHighHistory) > 0
        array.pop(swingHighHistory)
        array.pop(swingHighHistoryBars)
    array.push(swingHighHistory, pivH)
    array.push(swingHighHistoryBars, newSwingBar)
    if array.size(swingHighHistory) > SWING_HISTORY_CAP
        array.shift(swingHighHistory)
        array.shift(swingHighHistoryBars)

if not na(pivL)
    lastSwingLowLevel := pivL
    lastSwingLowBar := newSwingBar
    lastSwingKind := -1
    if replaceLast and array.size(swingLowHistory) > 0
        array.pop(swingLowHistory)
        array.pop(swingLowHistoryBars)
    array.push(swingLowHistory, pivL)
    array.push(swingLowHistoryBars, newSwingBar)
    if array.size(swingLowHistory) > SWING_HISTORY_CAP
        array.shift(swingLowHistory)
        array.shift(swingLowHistoryBars)

// Walk-back stop finders — iterate the swing history from most-recent to
// oldest, return the first level on the correct side of `entryPx`. This
// mirrors Python's `_find_swing_stop_level` (ml/src/pac_backtest/loop.py)
// which:
//   1. Walks back through swings to find a correct-side level (because the
//      most-recent swing is often on the WRONG side of entry).
//   2. EXCLUDES the signal bar itself — a bullish BOS frequently coincides
//      with a new swing-low confirmation at the signal bar, which if used
//      plants the stop at the profit side of entry.
// `signalBar` is the bar where the BOS fired. At entry detection we're on
// bar N+1 (entry fills at bar N+1 open after signal at bar N close), so
// signalBar = bar_index - 1. Any pivot confirmed at barIdx >= signalBar is
// excluded to match Python's `range(signal_idx - 1, ...)`.
findLongStop(entryPx, atrVal, signalBar) =>
    float result = na
    n = array.size(swingLowHistory)
    if n > 0
        for i = n - 1 to 0
            barIdx = array.get(swingLowHistoryBars, i)
            if barIdx >= signalBar
                continue
            level = array.get(swingLowHistory, i)
            if level < entryPx
                result := level
                break
    na(result) ? entryPx - stopATRMult * atrVal : result

findShortStop(entryPx, atrVal, signalBar) =>
    float result = na
    n = array.size(swingHighHistory)
    if n > 0
        for i = n - 1 to 0
            barIdx = array.get(swingHighHistoryBars, i)
            if barIdx >= signalBar
                continue
            level = array.get(swingHighHistory, i)
            if level > entryPx
                result := level
                break
    na(result) ? entryPx + stopATRMult * atrVal : result

bosBull = not na(lastSwingHighLevel) and close > lastSwingHighLevel and close[1] <= lastSwingHighLevel
bosBear = not na(lastSwingLowLevel) and close < lastSwingLowLevel and close[1] >= lastSwingLowLevel

var float prevSwingLowLevel = na
var float prevSwingHighLevel = na
if not na(pivL)
    prevSwingLowLevel := lastSwingLowLevel[1]
if not na(pivH)
    prevSwingHighLevel := lastSwingHighLevel[1]

chochBear = not na(pivL) and not na(prevSwingLowLevel) and pivL < prevSwingLowLevel
chochBull = not na(pivH) and not na(prevSwingHighLevel) and pivH > prevSwingHighLevel

// ============================ ENTRY GATE ============================
longEntry = bosBull and inRTH and not isEventDay and (zClose > effMinZVWAP)
shortEntry = bosBear and inRTH and not isEventDay and (zClose < -effMinZVWAP)

// ============================ VISUAL MARKERS ============================
swingOffset = -swingLen
plotshape(showSwings and not na(pivH), title="Swing High", style=shape.circle, location=location.abovebar, color=color.new(color.red, 40), size=size.tiny, offset=swingOffset)
plotshape(showSwings and not na(pivL), title="Swing Low", style=shape.circle, location=location.belowbar, color=color.new(color.green, 40), size=size.tiny, offset=swingOffset)

if showBOSLines and bosBull
    line.new(lastSwingHighBar, lastSwingHighLevel, bar_index, lastSwingHighLevel, color=color.new(color.blue, 30), width=2, style=line.style_solid)
if showBOSLines and bosBear
    line.new(lastSwingLowBar, lastSwingLowLevel, bar_index, lastSwingLowLevel, color=color.new(color.blue, 30), width=2, style=line.style_solid)

// ============================ STRATEGY ORDERS ============================
// Entries — pass qty=1 explicitly to avoid any default_qty ambiguity.
// `strategy.opentrades == 0` is the officially-recommended flat-check pattern.
if longEntry and strategy.opentrades == 0
    strategy.entry("Long", strategy.long, qty=1)
if shortEntry and strategy.opentrades == 0
    strategy.entry("Short", strategy.short, qty=1)

// Stops + optional target. The stop is FROZEN at entry — Python's engine
// computes the stop once when the signal fires and holds it static for the
// duration of the trade. Our earlier Pine version re-computed the stop on
// every bar via findLongStop, which effectively trailed the stop to newer
// (tighter) swing lows as price rallied, and got whipsawed on normal
// retraces. Freezing the stop on the bar where the position opens fixes
// that: longStopFrozen / shortStopFrozen are assigned once on the entry
// bar and remain constant until the trade closes. They reset to na on flat.
var float longStopFrozen = na
var float longTargetFrozen = na
var float shortStopFrozen = na
var float shortTargetFrozen = na

justOpenedLong = strategy.position_size > 0 and nz(strategy.position_size[1], 0.0) <= 0
justOpenedShort = strategy.position_size < 0 and nz(strategy.position_size[1], 0.0) >= 0

// Entry fills at bar N+1 open (from signal at bar N close). At entry
// detection `bar_index` = N+1, so the signal bar is `bar_index - 1` (= N).
signalBarIdx = bar_index - 1

if justOpenedLong
    entryPx = strategy.opentrades.entry_price(0)
    longStopFrozen := findLongStop(entryPx, atr14, signalBarIdx)
    longTargetFrozen := effExitMode == "ATR_TARGET" ? entryPx + effTargetATR * atr14 : na

if justOpenedShort
    entryPx = strategy.opentrades.entry_price(0)
    shortStopFrozen := findShortStop(entryPx, atr14, signalBarIdx)
    shortTargetFrozen := effExitMode == "ATR_TARGET" ? entryPx - effTargetATR * atr14 : na

// Reset frozen levels when flat so next trade recomputes fresh.
if strategy.opentrades == 0
    longStopFrozen := na
    longTargetFrozen := na
    shortStopFrozen := na
    shortTargetFrozen := na

strategy.exit("LongX", from_entry="Long", stop=longStopFrozen, limit=longTargetFrozen, comment_loss="STOP", comment_profit="TARGET")
strategy.exit("ShortX", from_entry="Short", stop=shortStopFrozen, limit=shortTargetFrozen, comment_loss="STOP", comment_profit="TARGET")

// CHoCH exit (OPPOSITE_CHOCH mode only)
if effExitMode == "OPPOSITE_CHOCH" and strategy.position_size > 0 and chochBear
    strategy.close("Long", comment="CHOCH")
if effExitMode == "OPPOSITE_CHOCH" and strategy.position_size < 0 and chochBull
    strategy.close("Short", comment="CHOCH")

// BoS counter — count same-direction BOS events post-entry, exit after N
var int bosCountSinceEntry = 0
barsInTrade = strategy.opentrades > 0 ? bar_index - strategy.opentrades.entry_bar_index(0) : 0
if barsInTrade == 0
    bosCountSinceEntry := 0
if strategy.position_size > 0 and bosBull and barsInTrade > 0
    bosCountSinceEntry := bosCountSinceEntry + 1
if strategy.position_size < 0 and bosBear and barsInTrade > 0
    bosCountSinceEntry := bosCountSinceEntry + 1

if effExitAfterNBos > 0 and strategy.position_size > 0 and bosCountSinceEntry >= effExitAfterNBos
    strategy.close("Long", comment="BOS" + str.tostring(effExitAfterNBos))
if effExitAfterNBos > 0 and strategy.position_size < 0 and bosCountSinceEntry >= effExitAfterNBos
    strategy.close("Short", comment="BOS" + str.tostring(effExitAfterNBos))

// Opposite-signal exit (raw bosBear / bosBull regardless of entry filters)
if strategy.position_size > 0 and bosBear
    strategy.close("Long", comment="OPP")
if strategy.position_size < 0 and bosBull
    strategy.close("Short", comment="OPP")

// Session-end forced flat
sessionEnded = strategy.position_size != 0 and inRTH[1] and not inRTH
if sessionEnded
    strategy.close_all(comment="EOD")

// ============================ DIAGNOSTIC PLOTS ============================
plotshape(showDiagnostic and longEntry, title="DIAG: longEntry", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.large, text="L-sig")
plotshape(showDiagnostic and shortEntry, title="DIAG: shortEntry", style=shape.triangledown, location=location.abovebar, color=color.new(color.fuchsia, 0), size=size.large, text="S-sig")
plotshape(showDiagnostic and inRTH and not inRTH[1], title="DIAG: RTH open", style=shape.arrowup, location=location.bottom, color=color.aqua, size=size.small, text="RTH")
