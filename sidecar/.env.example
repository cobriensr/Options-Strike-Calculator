# Database (same Neon instance as Vercel app)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Databento
DATABENTO_API_KEY=

# Twilio SMS alerts (optional -- alerts will log-only if not configured)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_PHONE_NUMBER=

# Runtime
PORT=8080
LOG_LEVEL=INFO
