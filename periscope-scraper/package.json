{
  "name": "@strike-calculator/periscope-scraper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Long-running Railway service that scrapes UW Periscope HTML every 10 minutes during RTH and persists per-strike Gamma/Charm/Vanna/Positions to Postgres.",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint . --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@sentry/node": "^8.45.0",
    "node-html-parser": "^7.0.1",
    "pino": "^9.5.0",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
