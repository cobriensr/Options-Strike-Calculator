{
  "name": "@strike-calculator/periscope-scraper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Long-running Railway service that scrapes UW Periscope HTML every 10 minutes during RTH and persists per-strike Gamma/Charm/Vanna/Positions to Postgres.",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint . --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@sentry/node": "^10.52.0",
    "node-html-parser": "^7.0.1",
    "pino": "^10.3.1",
    "playwright": "^1.49.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^10.3.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  }
}
