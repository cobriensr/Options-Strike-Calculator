{
  "name": "strike-calculator-daemon",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "TRACE Live capture daemon — runs Playwright via browserless.io every 5 min during market hours, POSTs gamma/charm/delta heatmap captures to /api/trace-live-analyze.",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx --watch src/index.ts",
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@sentry/node": "^10.21.0",
    "pino": "^10.0.0",
    "pino-pretty": "^13.0.0",
    "playwright-core": "^1.56.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
