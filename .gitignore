# Lottery Finder — also ignore the 3 BIG computational intermediates
# (>20MB each, ~155MB combined). These are regenerable from committed
# scripts in <20 min total. Keep small load-bearing summaries tracked.
#   p14_event_triggers.csv  (60MB) — regen: p14_event_trigger.py (~10 min)
#   p27_policy_grid.csv     (22MB) — regen: p27_exit_policy_grid.py (~5 min)
#   macro_strike_gex.csv    (72MB) — regen: dump_macro_tables.ts (~1 min)
docs/tmp/options-flow-analysis/outputs/p14_event_triggers.csv
docs/tmp/options-flow-analysis/outputs/p27_policy_grid.csv
docs/tmp/options-flow-analysis/outputs/macro_strike_gex.csv

# Python bytecode cache in scripts dir
docs/tmp/options-flow-analysis/scripts/__pycache__/
