# Claude — ignore everything by default, but un-ignore the three SKILL.md
# files that api/trace-live-analyze.ts loads at module init. They're project
# IP (analytical lens for charm/delta/gamma pressure) and must ship in the
# Vercel function bundle. Vercel's bundler skips gitignored files even when
# matched by includeFiles, so they have to be tracked.
.claude/*
!.claude/skills
.claude/skills/*
!.claude/skills/charm-pressure
!.claude/skills/delta-pressure
!.claude/skills/gamma
.claude/skills/charm-pressure/*
.claude/skills/delta-pressure/*
.claude/skills/gamma/*
!.claude/skills/charm-pressure/SKILL.md
!.claude/skills/delta-pressure/SKILL.md
!.claude/skills/gamma/SKILL.md
.vercel
.env*.local
.clone/

# Sonar
.scannerwork/

# Playwright
.playwright-mcp/

# Serena
.serena/

# ML
ml/.venv/
ml/*.csv
ml/data/
ml/trace/results/
ml/trace/images/
ml/.pytest_cache/
ml/.ruff_cache/
ml/htmlcov/
ml/.coverage

# Python bytecode caches — single pattern covers all current + future subdirs
**/__pycache__/

# Experimental ML run outputs — regenerable from ml/scripts/.
# Findings + reports markdown docs are the durable summaries.
ml/experiments/sweeps/
ml/experiments/pac_a2/
ml/experiments/pac_replay/
ml/experiments/pac_classifier/
ml/experiments/ichimoku_classifier/
ml/experiments/sweep_run_*.log
ml/experiments/phase2_early_*.json

# TypeScript incremental build cache
tsconfig.tsbuildinfo

# Superpowers
.superpowers/

# ml-sweep Railway service
ml-sweep/.env*
ml-sweep/.venv/

# Capture-study scratch dirs — track code (.py / .ts / .mjs / .md) only;
# ignore data outputs (CSVs, screenshots, study artifacts, auth state).
scripts/charm-pressure-capture/.trace-storage.json
scripts/charm-pressure-capture/screenshots/
scripts/charm-pressure-capture/*.csv
scripts/charm-pressure-capture/*.csv.bak
scripts/charm-pressure-capture/findings/
scripts/charm-pressure-capture/plots/
scripts/charm-pressure-capture/scoring/
scripts/delta-pressure-capture/screenshots/
scripts/delta-pressure-capture/*.csv
scripts/delta-pressure-capture/*.csv.bak
scripts/gamma-capture/screenshots/
scripts/gamma-capture/*.csv
scripts/gamma-capture/*.csv.bak
